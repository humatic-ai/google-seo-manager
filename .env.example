# Google SEO Manager — Configuration
# Copy to .env and fill in your values:  cp .env.example .env && chmod 600 .env

# Site & crawl settings
SEO_SITE_URL=sc-domain:YOUR_DOMAIN.com
SEO_COOLDOWN_HOURS=48
SEO_INDEXING_API_ENABLED=true
SEO_DB_PATH=seo_submissions.db
SEO_USER_AGENT=Google-SEO-Manager/1.0
SEO_REQUEST_DELAY=1.5

# Email reporting
SEO_EMAIL_TO=you@example.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IndexNow (disabled by default)
# SEO_INDEXNOW_ENABLED=false
# SEO_INDEXNOW_KEY=your-indexnow-key

# Overrides (uncomment if needed)
# SEO_CREDENTIALS_FILE=credentials.json
# SEO_SITEMAP_URL=https://your-domain.com/sitemap.xml
# SEO_SITEMAP_LOCAL_FALLBACK=/path/to/local/sitemap.xml
